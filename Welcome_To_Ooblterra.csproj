<Project Sdk="Microsoft.NET.Sdk">

    <!-- BepInEx Properties -->
    <PropertyGroup>
        <AssemblyName>Welcome_To_Ooblterra</AssemblyName>
        <Product>Welcome_To_Ooblterra</Product>
        <!-- Change to whatever version you're currently on. -->
        <Version>1.0.0</Version>
    </PropertyGroup>

    <!-- Project Properties -->
    <PropertyGroup>
        <TargetFramework>netstandard2.1</TargetFramework>
        <RootNamespace>Welcome_To_Ooblterra</RootNamespace>
        <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
        <LangVersion>latest</LangVersion>
    </PropertyGroup>

    <!-- Enable Nullable for better IDE null-checking -->
    <PropertyGroup>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <PropertyGroup>
        <PluginsDirectory>.\plugins\</PluginsDirectory>
        <!-- If running with Unity project, this will be a valid path to the project's plugin directory. If not, this folder does not exist -->
        <UnityProjectDirectory>..\WelcomeToOoblterra73\</UnityProjectDirectory>
        <UnityPluginsDirectory>$(UnityProjectDirectory)Assets\LethalCompany\Mods\plugins\</UnityPluginsDirectory>
    </PropertyGroup>

    <!-- Load local unity path from user specific props file -->
    <Import Project="Welcome_To_Ooblterra.local.props" Condition="Exists('Welcome_To_Ooblterra.local.props')" />    

    <!-- Set NuGet Sources -->
    <PropertyGroup>
        <RestoreAdditionalProjectSources>
            https://api.nuget.org/v3/index.json;
            https://nuget.bepinex.dev/v3/index.json;
            https://nuget.windows10ce.com/nuget/v3/index.json <!-- This source lets you reference mods from thunderstore if they aren't on NuGet -->
        </RestoreAdditionalProjectSources>
    </PropertyGroup>

    <!-- Embed Debug Symbols for Easier Debugging -->
    <PropertyGroup>
        <DebugSymbols>true</DebugSymbols>
        <DebugType>embedded</DebugType>
        <!--
        Trim the project path to prevent players from potentially
        viewing Private Information in stack traces.
        -->
        <PathMap>$([System.IO.Path]::GetFullPath('$(MSBuildThisFileDirectory)'))=./</PathMap>
    </PropertyGroup>

    <!-- Required for allowing access to private members in the lethal company dll -->
    <ItemGroup>
        <PackageReference Include="BepInEx.AssemblyPublicizer.MSBuild" Version="0.4.1" PrivateAssets="all"/>
    </ItemGroup>

    <!-- Dependencies when running in own repo -->
