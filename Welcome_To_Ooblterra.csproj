    <!-- Dependencies when running in unity project -->
    <ItemGroup Condition="Exists('$(UnityPluginsDirectory)')">
        <!-- Build against the assemblies in the Unity project and Unity engine installation-->

        <!-- References from the actual steam game directory -->
        <Reference Include="UnityEngine">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.AnimationModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.AnimationModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.AudioModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.AudioModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.PhysicsModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.PhysicsModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.ParticleSystemModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.ParticleSystemModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.AssetBundleModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.AssetBundleModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.CoreModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.CoreModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.AIModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.AIModule.dll</HintPath>
        </Reference>
        <Reference Include="UnityEngine.JSONSerializeModule">
            <HintPath>$(UnityEngineManagedDirectory)UnityEngine.JSONSerializeModule.dll</HintPath>
        </Reference>
        <Reference Include="Unity.RenderPipelines.HighDefinition.Runtime">
            <HintPath>$(UnityEngineManagedDirectory)Unity.RenderPipelines.HighDefinition.Runtime.dll</HintPath>
        </Reference>
        <Reference Include="Unity.Netcode.Runtime">
            <HintPath>$(UnityEngineManagedDirectory)Unity.Netcode.Runtime.dll</HintPath>
        </Reference>
        <Reference Include="Assembly-CSharp" Publicize="true" >
            <HintPath>$(UnityEngineManagedDirectory)Assembly-CSharp.dll</HintPath>
            <Private>false</Private>
        </Reference>

        <!-- BepInEx references -->
        <Reference Include="0Harmony">
            <HintPath>$(UnityProjectDirectory)Lethal Company\BepInEx\core\0Harmony.dll</HintPath>
        </Reference>
        <Reference Include="BepInEx">
            <HintPath>$(UnityProjectDirectory)Lethal Company\BepInEx\core\BepInEx.dll</HintPath>
        </Reference>

        <!-- References to other mods-->
        <Reference Include="LethalLib">
            <HintPath>$(UnityPluginsDirectory)Evaisa-LethalLib\LethalLib\LethalLib.dll</HintPath>
        </Reference>
        <Reference Include="LethalLevelLoader">
            <HintPath>$(UnityPluginsDirectory)IAmBatby-LethalLevelLoader\LethalLevelLoader.dll</HintPath>
        </Reference>
        <Reference Include="MMHOOK_Assembly-CSharp">
            <HintPath>$(UnityPluginsDirectory)MMHOOK\MMHOOK_Assembly-CSharp.dll</HintPath>
        </Reference>
    </ItemGroup>

    <ItemGroup Condition="'$(TargetFramework.TrimEnd(`0123456789`))' == 'net'">
        <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.2" PrivateAssets="all"/>
    </ItemGroup>

    <!-- Netcode Patcher Post-Build Event for command line -->
    <Sdk Name="Evaisa.NetcodePatcher.MSBuild" Version="4.4.1" />
    <PropertyGroup>
        <NetcodePatcherUnityVersion>2022.3.62</NetcodePatcherUnityVersion>
        <NetcodePatcherNetcodeVersion>1.12.0</NetcodePatcherNetcodeVersion>
        <NetcodePatcherTransportVersion>1.0.0</NetcodePatcherTransportVersion>
    </PropertyGroup>
    <ItemGroup>
        <NetcodePatch Include="$(TargetPath)" />
    </ItemGroup>

    <!-- Netcode patch to run in visual studio builds -->
    <PropertyGroup>
        <MSBuildWarningsAsMessages>$(MSBuildWarningsAsMessages);NCP0001</MSBuildWarningsAsMessages>
    </PropertyGroup>

    <Target Name="LegacyNetcodePatch" AfterTargets="NetcodePatch" Condition="'$(MSBuildRuntimeType)' != 'Core'">
        <!-- run the CLI patcher only for MSBuilds that cannot load the dependencies -->
        <Exec Command="netcode-patch -nv 1.5.2 &quot;$(TargetPath)&quot; @(ReferencePathWithRefAssemblies->'&quot;%(Identity)&quot;', ' ')"/>
    </Target>

    <!-- After build, copy assembly to Unity project for testing if running as submodule of Unity project -->
    <Target Condition="Exists('$(UnityPluginsDirectory)')" Name="CopyToUnity" DependsOnTargets="NetcodePatch" AfterTargets="PostBuildEvent">
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(UnityPluginsDirectory)Welcome_To_Ooblterra"/>
    </Target>

</Project>
